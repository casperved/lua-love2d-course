{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "love: run current folder",
      "type": "shell",
      "command": "${config:love2d.executablePath}",
      "args": ["${fileDirname}"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "love: run starter",
      "type": "shell",
      "command": "${config:love2d.executablePath}",
      "args": ["${fileDirname}/starter"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "love: run solution",
      "type": "shell",
      "command": "${config:love2d.executablePath}",
      "args": ["${fileDirname}/solution"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
